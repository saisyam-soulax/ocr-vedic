# Logging
# Set to DEBUG for verbose per-page and dispatch logs, INFO (default) for actionable summaries.
LOG_LEVEL=INFO

# Google Gemini
GOOGLE_API_KEY=
# Vision-capable Gemini (override when newer tiers ship, e.g. gemini-3-*)
GEMINI_MODEL=gemini-3.1-pro-preview
# Comma-separated allowlist surfaced in GET /api/providers (defaults to GEMINI_MODEL if unset)
GEMINI_MODEL_OPTIONS=
# Set to true if your key is a Vertex AI / Agentic Platform key (not a public AI Studio key)
GEMINI_USE_VERTEXAI=false
# Required when GEMINI_USE_VERTEXAI=true: GCP project id (numeric or name) and region
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1

# Gemini cost logs (per OCR job + persistent administrator ledger)
# Rates: https://ai.google.dev/gemini-api/docs/pricing (Standard paid tier)
GEMINI_COST_LOG_ENABLED=true
# GEMINI_COST_LEDGER_DIR=/path/to/backend/data/gemini_costs
# Optional: require X-Admin-Key header on GET /api/admin/gemini-costs*
ADMIN_API_KEY=

# AWS Bedrock
AWS_REGION=us-west-2
# Optional named profile (also respects AWS_PROFILE if unset here)
AWS_PROFILE=

# Credential sources (same as boto3): environment variables AWS_ACCESS_KEY_ID,
# AWS_SECRET_ACCESS_KEY, and optional AWS_SESSION_TOKEN; or ~/.aws credentials from
# `aws configure` / AWS_PROFILE. You do not have to duplicate keys in .env if your shell/profile already exports them.

# Claude on Bedrock (example — use an ID enabled in your account/region)
BEDROCK_CLAUDE_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# Comma-separated allowlist for Bedrock Claude (defaults to BEDROCK_CLAUDE_MODEL_ID)
BEDROCK_CLAUDE_MODEL_OPTIONS=

# Open multimodal on Bedrock (Llama 3.2 vision, Nova, etc. — must support Converse + images)
BEDROCK_OCR_MODEL_ID=meta.llama3-2-11b-instruct-v1:0
# Comma-separated allowlist for open Bedrock OCR model (defaults to BEDROCK_OCR_MODEL_ID)
BEDROCK_OCR_MODEL_OPTIONS=

# Local vLLM — dots.ocr (rednote-hilab/dots.ocr) on GPU
# docker compose --profile vllm up -d --build
# DGX Spark GB10: single GPU; use VLLM_ON_DEMAND=true to load/stop from the UI.
VLLM_ENABLED=false
VLLM_BASE_URL=http://vllm:8000/v1
# Must match vLLM --served-model-name (default in docker-compose: model)
VLLM_MODEL=model
VLLM_MODEL_OPTIONS=model,rednote-hilab/dots.ocr
VLLM_API_KEY=
VLLM_REQUEST_TIMEOUT_SECONDS=600
VLLM_ON_DEMAND=false
VLLM_CONTAINER_NAME=ocr-vedic-vllm-1
VLLM_WARMUP_ON_LOAD=false
# Hugging Face token (recommended for first-time model download)
# HF_TOKEN=
# NVIDIA_VISIBLE_DEVICES=0
# Required on DGX Spark GB10 until using a Blackwell-built vLLM image:
# VLLM_USE_FLASHINFER_SAMPLER=0
# vLLM memory — SHARED GPU (other processes keep running):
#   utilization <= (free_GiB * 0.9) / (total_GiB)  from `nvidia-smi`
# VLLM_GPU_MEMORY_UTILIZATION=auto
# or fixed, e.g. 0.03 when free ≈ 4.3 GiB of 119.7 GiB
# VLLM_MAX_MODEL_LEN=4096
# VLLM_MAX_NUM_BATCHED_TOKENS=2048
# Completion cap (default: MAX_MODEL_LEN - 3200 for system prompt + image)
# VLLM_MAX_OUTPUT_TOKENS=896
# VLLM_INPUT_TOKEN_RESERVE=3200
# VLLM_CPU_OFFLOAD_GB=16
# Dedicated GPU (no other CUDA jobs):
# VLLM_GPU_MEMORY_UTILIZATION=0.45
# VLLM_MAX_MODEL_LEN=16384
# VLLM_MAX_NUM_BATCHED_TOKENS=8192
# dots.ocr pipeline alignment (run_ocr_pipeline.py / ocr_pipeline/)
# PDF DPI for vllm_dots rasterization.
# 150 (default) fits a 4096-token context on a shared GPU.
# 250 matches run_ocr_pipeline.py quality but needs VLLM_MAX_MODEL_LEN>=8192.
# VLLM_PDF_DPI=150
# VLLM_PREPROCESS_IMAGES=true
# VLLM_TEMPERATURE=0.1
# VLLM_TOP_P=0.9
# Optional: same PROMPT = '''...''' file as the standalone pipeline
# VLLM_PROMPT_FILE=/path/to/prompt.txt
# VLLM_USE_FULL_SYSTEM_PROMPT=false

# Server tuning
OCR_REQUEST_TIMEOUT_SECONDS=120
# Comma-separated origins for browser dev (used by FastAPI CORSMiddleware)
# Include your LAN IP so browsers on the network can call the API when needed
# Production UI is at http://<LAN-IP>/ocr/ (same origin — CORS only needed for dev / cross-origin)
CORS_ORIGINS=http://172.16.1.30,http://172.16.1.30/ocr,http://172.16.1.30:80,http://localhost:5173,http://localhost:5173/ocr,http://127.0.0.1:5173

# OCR uploads: each request is persisted under UPLOAD_STORAGE_DIR/<uuid>/ (original filenames + metadata.json).
# Default when unset is <directory-above-backend-app>/data/uploads (e.g. backend/data/uploads in this repo).
# UPLOAD_STORAGE_DIR=/absolute/or/relative/path
# After a successful OCR, delete that batch folder (default false keeps disk tidy; set true to inspect uploads later).
UPLOAD_RETAIN=false
# When > 0, remove batch folders whose mtime is older than this many hours (empty failed runs, or old retained batches).
UPLOAD_RETAIN_HOURS=168

# Docker: when the Vite dev server runs in Compose, point the dev proxy at the API service
# VITE_API_PROXY_TARGET=http://backend:8000
# Long multipart + OCR responses (ms); default 15 minutes when unset
# VITE_PROXY_TIMEOUT_MS=900000
